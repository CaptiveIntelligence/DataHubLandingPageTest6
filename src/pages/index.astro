// Attempt to fetch from Sanity — fall back gracefully if env vars are missing
let data: { settings: any; page: any } | null = null;

const projectId = import.meta.env.SANITY_PROJECT_ID;
if (projectId) {
  try {
    const { sanityClient } = await import('../lib/sanity');
    const { PAGE_QUERY } = await import('../lib/queries');
    data = await sanityClient.fetch(PAGE_QUERY);
  } catch (e) {
    console.warn('Sanity fetch failed, using default content:', e);
  }
}

