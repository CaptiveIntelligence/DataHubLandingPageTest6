  <title>Captive Intelligence — CI Data Hub</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>

  <Nav
    links={nav.links}
    signInLabel={nav.signInLabel}
    demoButtonLabel={nav.demoButtonLabel}
  />

  <Hero
    badge={hero.badge}
    headline={hero.headline}
    gradientWord={hero.gradientWord}
    subtext={hero.subtext}
    primaryCtaLabel={hero.primaryCtaLabel}
    secondaryCtaLabel={hero.secondaryCtaLabel}
    stats={hero.stats}
  />

  <LogosBar
    label={logosBar.label}
    logos={logosBar.logos}
  />

  <Platform
    badge={platform.badge}
    heading={platform.heading}
    subtext={platform.subtext}
    features={platform.features}
  />

  <DataCoverage
    badge={dataCoverage.badge}
    heading={dataCoverage.heading}
    subtext={dataCoverage.subtext}
    stats={dataCoverage.stats}
    detailHeading={dataCoverage.detailHeading}
    detailBody={dataCoverage.detailBody}
    coverageList={dataCoverage.coverageList}
    domiciles={dataCoverage.domiciles}
    ctaLabel={dataCoverage.ctaLabel}
  />

  <UseCases
    badge={useCases.badge}
    heading={useCases.heading}
    subtext={useCases.subtext}
    tabs={useCases.tabs}
  />

  <Testimonials
    badge={testimonials.badge}
    heading={testimonials.heading}
    items={testimonials.items}
  />

  <About
    badge={about.badge}
    heading={about.heading}
    paragraphs={about.paragraphs}
    values={about.values}
  />

  <CtaSection
    heading={cta.heading}
    subtext={cta.subtext}
    primaryCtaLabel={cta.primaryCtaLabel}
    secondaryCtaLabel={cta.secondaryCtaLabel}
    secondaryCtaHref={cta.secondaryCtaHref}
  />

  <Footer
    tagline={footer.tagline}
    columns={footer.columns}
    legalLinks={footer.legalLinks}
    copyright={footer.copyright}
  />

  <DemoModal
    heading={demoModal.heading}
    subtext={demoModal.subtext}
    roles={demoModal.roles}
    successHeading={demoModal.successHeading}
    successBody={demoModal.successBody}
  />

  <script>
    // Scroll-triggered animation observer (page-level)
    document.addEventListener('DOMContentLoaded', () => {
      const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -40px 0px',
      };
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      document.querySelectorAll(
        '.feature-card, .coverage-card, .testimonial-card, .value-card, .coverage-detail'
      ).forEach(el => {
        el.classList.add('anim-target');
        observer.observe(el);
      });
    });
  </script>

</body>
</html>
