---
export interface Props {
  links: { label: string; href: string }[];
  signInLabel: string;
  demoButtonLabel: string;
}

const { links, signInLabel, demoButtonLabel } = Astro.props;
---

<nav class="nav" id="nav">
  <div class="nav__inner">
    <a href="#" class="nav__logo">
      <img src="/images/Captive Intelligence Logo Long.png" alt="Captive Intelligence" />
    </a>
    <ul class="nav__links">
      {links.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
    <div class="nav__cta">
      <a href="#contact" class="btn btn--ghost btn--sm">{signInLabel}</a>
      <button class="btn btn--primary btn--sm" id="navDemoBtn">{demoButtonLabel}</button>
    </div>
    <button class="nav__burger" id="navBurger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="nav__mobile" id="navMobile">
    <ul>
      {links.map((link) => (
        <li><a href={link.href} class="nav-mobile-link">{link.label}</a></li>
      ))}
    </ul>
    <button class="btn btn--primary" id="navMobileDemoBtn">{demoButtonLabel}</button>
  </div>
</nav>

<script>
  // Scroll effect
  const nav = document.getElementById('nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 20);
    }, { passive: true });
  }

  // Mobile menu toggle
  const burger = document.getElementById('navBurger');
  const mobileMenu = document.getElementById('navMobile');
  burger?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('open');
  });

  // Close mobile menu on link click
  document.querySelectorAll('.nav-mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.remove('open');
    });
  });

  // Demo button — dispatch custom event
  document.getElementById('navDemoBtn')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('openDemoModal'));
  });

  document.getElementById('navMobileDemoBtn')?.addEventListener('click', () => {
    mobileMenu?.classList.remove('open');
    window.dispatchEvent(new CustomEvent('openDemoModal'));
  });

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (this: HTMLAnchorElement, e: Event) {
      const href = this.getAttribute('href');
      if (href === '#') return;
      const target = document.querySelector(href!);
      if (target) {
        e.preventDefault();
        const navEl = document.getElementById('nav');
        const navHeight = navEl ? navEl.offsetHeight : 72;
        const top = (target as HTMLElement).getBoundingClientRect().top + window.scrollY - navHeight - 16;
        window.scrollTo({ top, behavior: 'smooth' });
      }
    });
  });
</script>
