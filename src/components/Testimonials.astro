---
export interface Testimonial {
  quote: string;
  name: string;
  role: string;
  initials: string;
  isFeatured: boolean;
}

export interface Props {
  badge: string;
  heading: string;
  items: Testimonial[];
}

const { badge, heading, items } = Astro.props;
---

<section class="section section--mid">
  <div class="container">
    <div class="section__header">
      <div class="section__badge">{badge}</div>
      <h2>{heading}</h2>
    </div>
    <div class="testimonials-grid">
      {items.map((item) => (
        <div class={`testimonial-card${item.isFeatured ? ' testimonial-card--featured' : ''}`}>
          <div class="testimonial-card__stars">★★★★★</div>
          <p>"{item.quote}"</p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">{item.initials}</div>
            <div>
              <strong>{item.name}</strong>
              <span>{item.role}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
