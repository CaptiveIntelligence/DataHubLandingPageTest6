---
export interface Props {
  heading: string;
  subtext: string;
  roles: string[];
  successHeading: string;
  successBody: string;
}

const { heading, subtext, roles, successHeading, successBody } = Astro.props;
---

<div class="modal-overlay" id="modalOverlay">
  <div class="modal" id="modal">
    <button class="modal__close" id="modalClose" aria-label="Close">&times;</button>
    <div class="modal__header">
      <img src="/images/CI DataHub Logo - 1 Line.png" alt="CI Data Hub" class="modal__logo" />
      <h2>{heading}</h2>
      <p>{subtext}</p>
    </div>
    <form
      class="modal__form"
      id="demoForm"
      name="demo-request"
      method="POST"
      action="/"
      data-netlify="true"
      netlify-honeypot="bot-field"
    >
      <input type="hidden" name="form-name" value="demo-request" />
      <p class="hidden" style="display:none;">
        <label>Don't fill this out if you're human: <input name="bot-field" /></label>
      </p>
      <div class="form-row">
        <div class="form-group">
          <label for="firstName">First Name *</label>
          <input type="text" id="firstName" name="firstName" required placeholder="Jane" />
        </div>
        <div class="form-group">
          <label for="lastName">Last Name *</label>
          <input type="text" id="lastName" name="lastName" required placeholder="Smith" />
        </div>
      </div>
      <div class="form-group">
        <label for="email">Work Email *</label>
        <input type="email" id="email" name="email" required placeholder="jane@company.com" />
      </div>
      <div class="form-group">
        <label for="company">Company *</label>
        <input type="text" id="company" name="company" required placeholder="Your organisation" />
      </div>
      <div class="form-group">
        <label for="role">Your Role</label>
        <select id="role" name="role">
          <option value="">Select your role...</option>
          {roles.map((role) => (
            <option>{role}</option>
          ))}
        </select>
      </div>
      <div class="form-group">
        <label for="message">What are you looking to achieve?</label>
        <textarea id="message" name="message" rows={3} placeholder="Tell us a bit about your needs..."></textarea>
      </div>
      <button type="submit" class="btn btn--primary btn--full">Request Demo →</button>
      <p class="form-note">We'll be in touch within one business day. No spam, ever.</p>
    </form>
    <div class="modal__success hidden" id="formSuccess">
      <div class="success-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
      </div>
      <h3>{successHeading}</h3>
      <p>{successBody}</p>
      <button class="btn btn--primary" id="successCloseBtn">Close</button>
    </div>
  </div>
</div>

<script>
  const overlay = document.getElementById('modalOverlay');
  const demoForm = document.getElementById('demoForm') as HTMLFormElement | null;
  const formSuccess = document.getElementById('formSuccess');

  function openModal() {
    overlay?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay?.classList.remove('open');
    document.body.style.overflow = '';
    setTimeout(() => {
      demoForm?.classList.remove('hidden');
      formSuccess?.classList.add('hidden');
      demoForm?.reset();
    }, 300);
  }

  // Listen for custom events
  window.addEventListener('openDemoModal', openModal);
  window.addEventListener('closeDemoModal', closeModal);

  // Close button
  document.getElementById('modalClose')?.addEventListener('click', closeModal);
  document.getElementById('successCloseBtn')?.addEventListener('click', closeModal);

  // Close on overlay click
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // Form submit — show success (for non-Netlify local dev)
  // On Netlify, the form will POST and redirect; this handles the JS-only case
  demoForm?.addEventListener('submit', (e) => {
    // Only intercept if not on Netlify (no form-name header means dev mode)
    // In production Netlify intercepts at CDN level before this fires for static sites
    // For the static output we'll let Netlify handle it, but show success in JS-only scenario
    e.preventDefault();
    demoForm.classList.add('hidden');
    formSuccess?.classList.remove('hidden');
  });
</script>
