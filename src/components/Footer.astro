---
export interface FooterLink {
  label: string;
  href: string;
}

export interface FooterColumn {
  heading: string;
  links: FooterLink[];
}

export interface Props {
  tagline: string;
  columns: FooterColumn[];
  legalLinks: FooterLink[];
  copyright: string;
}

const { tagline, columns, legalLinks, copyright } = Astro.props;
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <img src="/images/Captive Intelligence Logo Long.png" alt="Captive Intelligence" class="footer__logo" />
        <p>{tagline}</p>
      </div>
      <div class="footer__links">
        {columns.map((col) => (
          <div class="footer__col">
            <h5>{col.heading}</h5>
            <ul>
              {col.links.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
    <div class="footer__bottom">
      <p>{copyright}</p>
      <div class="footer__legal">
        {legalLinks.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
